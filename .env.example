# Public env vars — copy to `.env.local` and adjust.

# WhatsApp Business / mobile number: country code + digits only, no spaces (e.g. Turkey)
NEXT_PUBLIC_WHATSAPP_NUMBER=905551234567

# Shown in mailto: and footer fallback link
NEXT_PUBLIC_CONTACT_EMAIL=siparis@crumbella.com

# Optional: tel: link in footer (E.164 style)
NEXT_PUBLIC_PHONE_TEL=+905551234567

# Canonical site URL for Open Graph / metadataBase
NEXT_PUBLIC_SITE_URL=https://crumbella.com
